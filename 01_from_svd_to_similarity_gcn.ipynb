import numpy as np
import networkx as nx
import torch
import torch.nn as nn
import matplotlib.pyplot as plt

# ==========================================
# ADIM 1: Çizgeyi (Graph) Oluşturma
# ==========================================
# Literatürün en meşhur "oyuncak" veri seti olan Karate Club ağını kullanalım.
G = nx.karate_club_graph()
N = G.number_of_nodes()

# Temel Matrisleri Çekelim
A = nx.to_numpy_array(G) # Komşuluk Matrisi
D = np.diag([deg for _, deg in G.degree()]) # Derece Matrisi

print(f"Grafik {N} düğümden oluşuyor.")

# ==========================================
# ADIM 2: Hoca'nın Tahtadaki Geçiş Matrisi (P) ve SVD
# ==========================================
# D^-1 * A işlemini yapıyoruz (Random Walk Transition Matrix)
D_inv = np.linalg.inv(D)
P = np.dot(D_inv, A)

# SVD (Tekil Değer Ayrışımı) ile Boyut Düşürme (Shallow Embedding)
# f(P) -> X işlemi
U, Sigma, Vt = np.linalg.svd(P)

d = 16 # Hedeflenen düşük boyut
node_embeddings_svd = U[:, :d] * np.sqrt(Sigma[:d])

print(f"SVD ile elde edilen Embedding Matrisi Boyutu: {node_embeddings_svd.shape}")

# ==========================================
# ADIM 3: High-Order Relation (Difüzyon / Katz)
# ==========================================
# R = (I - alpha * P)^-1 formülünün koda dökülmüş hali
alpha = 0.5 # Sönümleme faktörü (Decay factor)
I = np.eye(N)

# Çizge Difüzyon Matrisi (Sonsuz mertebeden ilişkiler)
R = np.linalg.inv(I - alpha * P)

# Eğer ağın global yapısını gömmek istiyorsak SVD'yi P'ye değil, R'ye uygularız
U_R, Sigma_R, Vt_R = np.linalg.svd(R)
node_embeddings_high_order = U_R[:, :d] * np.sqrt(Sigma_R[:d])

# ==========================================
# ADIM 4: Mustafa Hoca'nın Makalesi: Hub-Promoted Index (HPI)
# ==========================================
# Düğümler arasındaki anlamsal/yapısal benzerliği hesaplayalım.
S = np.zeros((N, N))

for u in range(N):
    for v in range(N):
        if u != v:
            # u ve v'nin ortak komşularını bul
            neighbors_u = set(G.neighbors(u))
            neighbors_v = set(G.neighbors(v))
            common_neighbors = len(neighbors_u.intersection(neighbors_v))
            
            # HPI Formülü: Ortak Komşular / min(derece_u, derece_v)
            min_degree = min(G.degree(u), G.degree(v))
            if min_degree > 0:
                S[u, v] = common_neighbors / min_degree

# Kendine dönüşleri (self-loops) 1 yapalım
np.fill_diagonal(S, 1.0)

# ==========================================
# ADIM 5: Similarity-Based GCN Katmanı (Deep Embedding)
# ==========================================
# Fiziksel A matrisi yerine, hesapladığımız HPI Benzerlik (S) matrisini kullanacağız.

class SimilarityGCNLayer(nn.Module):
    def __init__(self, in_features, out_features):
        super(SimilarityGCNLayer, self).__init__()
        # W ağırlık matrisi
        self.W = nn.Linear(in_features, out_features, bias=False)
        self.activation = nn.ReLU()

    def forward(self, S_matrix, X_features):
        # S * X * W işlemi
        # 1. Özellikleri ağırlıklarla çarp (X * W)
        support = self.W(X_features) 
        # 2. Benzerlik matrisi ile mesaj iletimi yap (S * (X*W))
        output = torch.matmul(S_matrix, support) 
        return self.activation(output)

# PyTorch Tensorlerine Çevirme
S_tensor = torch.FloatTensor(S)

# Düğümlerin başlangıç özellikleri (Feature X)
# Elimizde özellik olmadığı için şimdilik Birim Matris (One-hot) veriyoruz
X_tensor = torch.eye(N) 

# Modeli başlatalım (N boyutlu one-hot -> 16 boyutlu embedding)
gcn_layer = SimilarityGCNLayer(in_features=N, out_features=16)

# İleri yayılım (Forward pass) ile Derin Embeddingleri elde etme
node_embeddings_deep = gcn_layer(S_tensor, X_tensor)

print(f"Similarity-Based GCN Embedding Boyutu: {node_embeddings_deep.shape}")
